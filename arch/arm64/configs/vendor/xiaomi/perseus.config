CONFIG_BCM_GPS_SPI_DRIVER=y
CONFIG_BUILD_ARM64_DT_OVERLAY=y
CONFIG_FINGERPRINT_FPC_TEE=y
CONFIG_FINGERPRINT_GOODIX_TA=y
CONFIG_HALLS=y
# CONFIG_HARDEN_BRANCH_PREDICTOR is not set
CONFIG_IDT_P9220=y
CONFIG_MACH_XIAOMI=y
CONFIG_MACH_XIAOMI_E5=y
CONFIG_MACH_XIAOMI_SDM845=y
# CONFIG_MITIGATE_SPECTRE_BRANCH_HISTORY is not set
CONFIG_TOUCHSCREEN_FTS=y
CONFIG_TOUCHSCREEN_FTS_POWER_SUPPLY=y
CONFIG_TOUCHSCREEN_ST_FTS_V521=y
CONFIG_USE_ROHM_BU64753=y
# CONFIG_FINGERPRINT_FPC_SCREEN_NOTIFY is not set
# CONFIG_I2C_BY_DMA is not set
CONFIG_TOUCHSCREEN_FTS_DIRECTORY="focaltech_touch"
# CONFIG_TOUCHSCREEN_ST_DEBUG_FS is not set
