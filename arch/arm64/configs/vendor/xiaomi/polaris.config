CONFIG_TOUCHSCREEN_SYNAPTICS_DSX_FW_UPDATE_FORCE=y
# CONFIG_TOUCHSCREEN_SYNAPTICS_DSX_GESTURE_FORCE is not set
# CONFIG_TOUCHSCREEN_SYNAPTICS_DSX_PROXIMITY_FORCE is not set
CONFIG_TOUCHSCREEN_SYNAPTICS_DSX_RMI_DEV_FORCE=y
